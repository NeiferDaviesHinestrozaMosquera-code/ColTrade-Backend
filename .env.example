# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Database (Prisma → Supabase Postgres) ───────────────────────────────────
# Connection Pooling (Transaction mode – para NestJS)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct connection (para migraciones Prisma)
DIRECT_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-2.pooler.supabase.com:5432/postgres

# ─── JWT (Supabase JWT secret — Settings > API) ──────────────────────────────
JWT_SECRET=your-supabase-jwt-secret

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PYMES=price_...
STRIPE_PRICE_EMPRESARIAL=price_...

# ─── Redis (Upstash o local) ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Para Upstash TLS: REDIS_URL=rediss://:password@host:port

# ─── TRM / Superfinanciera ───────────────────────────────────────────────────
TRM_API_URL=https://www.datos.gov.co/resource/32sa-8pi3.json
